<?xml version="1.0" encoding="UTF-8"?>
<!--
  Material parameters for the 1-D SAGCM SPAD simulator.

  Each <material> contains:
    <property name="eps_r">     — static relative permittivity
    <property name="Eg_0K">      — bandgap at 0 K (Varshni)
    <varshni>  (alpha, beta)     — Varshni coefficients  Eg(T) = Eg0 - aT^2/(T+b)
    <dos>      (Nc_300K, Nv_300K, gamma) — effective DOS, scaled as T^gamma
    <mobility> (mu_n, mu_p)      — low-field mobility (cm^2/V·s)
    <saturation_velocity>         — high-field velocity saturation (cm/s)
    <effective_mass> (mc, mh)    — DOS effective masses (in units of m0)
    <ionization carrier="...">   — Okuto-Crowell parameters:
        lambda0 = optical phonon mean free path (cm)
        ER0     = optical phonon energy parameter (eV)
        hw_meV  = phonon energy (meV)
        Eth     = threshold energy (eV)
    <lifetime> (tau_n, tau_p)    — SRH trap lifetimes (s)

  All values in SI-cgs hybrid units (cm, eV, K, s) unless noted.
-->
<materials version="1.0" date="2026-07-08">
  <meta>
    <author>SPAD Simulator</author>
    <description>Material parameters for SPAD/APD device simulation.
All values in SI-cgs hybrid units (cm, eV, K, s) unless noted.</description>
  </meta>

  <material name="Si">
    <property name="eps_r" type="float" unit="1" description="Relative permittivity">11.7</property>
    <property name="Eg_0K" type="float" unit="eV" description="Bandgap at 0 K">1.12</property>
    <varshni>
      <alpha type="float" unit="eV/K" description="Varshni alpha">4.73e-4</alpha>
      <beta type="float" unit="K" description="Varshni beta">636.0</beta>
    </varshni>
    <dos>
      <Nc_300K type="float" unit="cm^-3" description="Conduction band DOS at 300 K">2.8e19</Nc_300K>
      <Nv_300K type="float" unit="cm^-3" description="Valence band DOS at 300 K">1.04e19</Nv_300K>
      <gamma type="float" unit="1" description="T-exponent for DOS">1.5</gamma>
    </dos>
    <mobility>
      <mu_n type="float" unit="cm^2/V·s" description="Electron mobility">1350.0</mu_n>
      <mu_p type="float" unit="cm^2/V·s" description="Hole mobility">450.0</mu_p>
    </mobility>
    <saturation_velocity>
      <vsat_n type="float" unit="cm/s" description="Electron saturation velocity">1.0e7</vsat_n>
      <vsat_p type="float" unit="cm/s" description="Hole saturation velocity">0.8e7</vsat_p>
    </saturation_velocity>
    <effective_mass>
      <mc type="float" unit="m0" description="Electron effective mass">0.26</mc>
      <mh type="float" unit="m0" description="Hole effective mass">0.49</mh>
    </effective_mass>
    <ionization carrier="electron">
      <lambda0 type="float" unit="cm" description="Optical phonon mean free path">5.4e-7</lambda0>
      <ER0 type="float" unit="eV" description="Optical phonon energy parameter">3.6e-2</ER0>
      <hw_meV type="float" unit="meV" description="Phonon energy">63.0</hw_meV>
      <Eth type="float" unit="eV" description="Threshold energy">1.8</Eth>
    </ionization>
    <ionization carrier="hole">
      <lambda0 type="float" unit="cm">5.0e-7</lambda0>
      <ER0 type="float" unit="eV">3.8e-2</ER0>
      <hw_meV type="float" unit="meV">65.0</hw_meV>
      <Eth type="float" unit="eV">1.8</Eth>
    </ionization>
    <lifetime>
      <tau_n type="float" unit="s" description="Electron trap lifetime">1e-6</tau_n>
      <tau_p type="float" unit="s" description="Hole trap lifetime">1e-6</tau_p>
    </lifetime>
  </material>

  <!-- InP multiplication region (high k ratio, wide gap, good for low-noise APDs). -->
  <!-- Values from: Xu et al., "Extracting dark current components...", Infr. Phys. & Tech. -->
  <material name="InP">
    <property name="eps_r" type="float" unit="1">12.5</property>
    <property name="Eg_0K" type="float" unit="eV">1.40</property>
    <varshni>
      <alpha type="float" unit="eV/K">4.5e-4</alpha>
      <beta type="float" unit="K">327.0</beta>
    </varshni>
    <dos>
      <Nc_300K type="float" unit="cm^-3">5.66e17</Nc_300K>
      <Nv_300K type="float" unit="cm^-3">2.03e19</Nv_300K>
      <gamma type="float" unit="1">1.5</gamma>
    </dos>
    <mobility>
      <mu_n type="float" unit="cm^2/V·s">4730.0</mu_n>
      <mu_p type="float" unit="cm^2/V·s">151.0</mu_p>
    </mobility>
    <saturation_velocity>
      <vsat_n type="float" unit="cm/s">2.5e7</vsat_n>
      <vsat_p type="float" unit="cm/s">2.0e7</vsat_p>
    </saturation_velocity>
    <effective_mass>
      <mc type="float" unit="m0">0.08</mc>
      <mh type="float" unit="m0">0.86</mh>
    </effective_mass>
    <ionization carrier="electron">
      <lambda0 type="float" unit="cm">4.2e-7</lambda0>
      <ER0 type="float" unit="eV">3.4e-2</ER0>
      <hw_meV type="float" unit="meV">42.0</hw_meV>
      <Eth type="float" unit="eV">2.1</Eth>
    </ionization>
    <ionization carrier="hole">
      <lambda0 type="float" unit="cm">3.8e-7</lambda0>
      <ER0 type="float" unit="eV">3.6e-2</ER0>
      <hw_meV type="float" unit="meV">44.0</hw_meV>
      <Eth type="float" unit="eV">2.1</Eth>
    </ionization>
    <lifetime>
      <tau_n type="float" unit="s">1e-9</tau_n>
      <tau_p type="float" unit="s">1e-9</tau_p>
    </lifetime>
    <!-- Xu et al. values not in current model: -->
    <!-- C_n (Auger, electron) = 3.7e-31 cm^6/s; C_p (Auger, hole) = 8.7e-30 cm^6/s -->
    <!-- B (radiative) = 2e-11 cm^3/s -->
  </material>

  <!-- InGaAs absorber (narrow gap, high absorption at 1300-1650 nm). -->
  <!-- Values from: Xu et al., "Extracting dark current components...", Infr. Phys. & Tech. -->
  <material name="InGaAs">
    <property name="eps_r" type="float" unit="1">13.9</property>
    <property name="Eg_0K" type="float" unit="eV">0.85</property>
    <varshni>
      <alpha type="float" unit="eV/K">4.5e-4</alpha>
      <beta type="float" unit="K">300.0</beta>
    </varshni>
    <dos>
      <Nc_300K type="float" unit="cm^-3">2.75e17</Nc_300K>
      <Nv_300K type="float" unit="cm^-3">7.62e18</Nv_300K>
      <gamma type="float" unit="1">1.5</gamma>
    </dos>
    <mobility>
      <mu_n type="float" unit="cm^2/V·s">12000.0</mu_n>
      <mu_p type="float" unit="cm^2/V·s">450.0</mu_p>
    </mobility>
    <saturation_velocity>
      <vsat_n type="float" unit="cm/s">2.5e7</vsat_n>
      <vsat_p type="float" unit="cm/s">2.0e7</vsat_p>
    </saturation_velocity>
    <effective_mass>
      <mc type="float" unit="m0">0.0489</mc>
      <mh type="float" unit="m0">0.45</mh>
    </effective_mass>
    <ionization carrier="electron">
      <lambda0 type="float" unit="cm">4.5e-7</lambda0>
      <ER0 type="float" unit="eV">3.5e-2</ER0>
      <hw_meV type="float" unit="meV">35.0</hw_meV>
      <Eth type="float" unit="eV">1.2</Eth>
    </ionization>
    <ionization carrier="hole">
      <lambda0 type="float" unit="cm">4.0e-7</lambda0>
      <ER0 type="float" unit="eV">3.7e-2</ER0>
      <hw_meV type="float" unit="meV">37.0</hw_meV>
      <Eth type="float" unit="eV">1.2</Eth>
    </ionization>
    <lifetime>
      <tau_n type="float" unit="s">1e-6</tau_n>
      <tau_p type="float" unit="s">1e-6</tau_p>
    </lifetime>
    <!-- Xu et al. values not in current model: -->
    <!-- C_n (Auger, electron) = 3.2e-28 cm^6/s; C_p (Auger, hole) = 3.2e-28 cm^6/s -->
    <!-- B (radiative) = 1.43e-10 cm^3/s -->
  </material>

  <!-- InGaAsP grading layer (quaternary, Eg ~ 1.0 eV, reduces valence-band barrier). -->
  <material name="InGaAsP">
    <property name="eps_r" type="float" unit="1">12.8</property>
    <property name="Eg_0K" type="float" unit="eV">1.0</property>
    <varshni>
      <alpha type="float" unit="eV/K">4.5e-4</alpha>
      <beta type="float" unit="K">310.0</beta>
    </varshni>
    <dos>
      <Nc_300K type="float" unit="cm^-3">3.5e17</Nc_300K>
      <Nv_300K type="float" unit="cm^-3">1.0e19</Nv_300K>
      <gamma type="float" unit="1">1.5</gamma>
    </dos>
    <mobility>
      <mu_n type="float" unit="cm^2/V·s">5000.0</mu_n>
      <mu_p type="float" unit="cm^2/V·s">200.0</mu_p>
    </mobility>
    <saturation_velocity>
      <vsat_n type="float" unit="cm/s">2.5e7</vsat_n>
      <vsat_p type="float" unit="cm/s">2.0e7</vsat_p>
    </saturation_velocity>
    <effective_mass>
      <mc type="float" unit="m0">0.06</mc>
      <mh type="float" unit="m0">0.5</mh>
    </effective_mass>
    <ionization carrier="electron">
      <lambda0 type="float" unit="cm">4.3e-7</lambda0>
      <ER0 type="float" unit="eV">3.4e-2</ER0>
      <hw_meV type="float" unit="meV">38.0</hw_meV>
      <Eth type="float" unit="eV">1.6</Eth>
    </ionization>
    <ionization carrier="hole">
      <lambda0 type="float" unit="cm">3.9e-7</lambda0>
      <ER0 type="float" unit="eV">3.6e-2</ER0>
      <hw_meV type="float" unit="meV">40.0</hw_meV>
      <Eth type="float" unit="eV">1.6</Eth>
    </ionization>
    <lifetime>
      <tau_n type="float" unit="s">1e-9</tau_n>
      <tau_p type="float" unit="s">1e-9</tau_p>
    </lifetime>
  </material>
</materials>
