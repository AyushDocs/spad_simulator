<materials version="1.0" date="2026-07-08">
  <meta>
    <author>SPAD Simulator</author>
    <description>Material parameters for SPAD/APD device simulation.
All values in SI-cgs hybrid units (cm, eV, K, s) unless noted.</description>
  </meta>

  <!-- ==================================================================== -->
  <!-- SILICON (Si)                                                         -->
  <!-- ==================================================================== -->
  <material name="Si">
    <!-- eps_r: Source = unknown / standard reference -->
    <property name="eps_r" type="float" unit="1" description="Relative permittivity">11.7</property>
    
    <!-- Eg_0K: Source = unknown / standard reference (Bludau 1974) -->
    <property name="Eg_0K" type="float" unit="eV" description="Bandgap at 0 K">1.17</property>
    
    <!-- E_trap: Source = calculated with formula (Eg_300K / 2.0 to model midgap traps) -->
    <property name="E_trap" type="float" unit="eV">0.56</property>
    
    <varshni>
      <!-- alpha, beta: Source = unknown / standard reference (Varshni 1967) -->
      <alpha type="float" unit="eV/K" description="Varshni alpha">4.73e-4</alpha>
      <beta type="float" unit="K" description="Varshni beta">636.0</beta>
    </varshni>
    
    <dos>
      <!-- Nc_300K, Nv_300K, gamma: Source = unknown / standard reference -->
      <Nc_300K type="float" unit="cm^-3" description="Conduction band DOS at 300 K">2.8e19</Nc_300K>
      <Nv_300K type="float" unit="cm^-3" description="Valence band DOS at 300 K">1.04e19</Nv_300K>
      <gamma type="float" unit="1" description="T-exponent for DOS">1.5</gamma>
    </dos>
    
    <mobility>
      <!-- mu_n, mu_p: Source = unknown / standard reference -->
      <mu_n type="float" unit="cm^2/V&#183;s" description="Electron mobility">1350.0</mu_n>
      <mu_p type="float" unit="cm^2/V&#183;s" description="Hole mobility">450.0</mu_p>
    </mobility>
    
    <saturation_velocity>
      <!-- vsat_n, vsat_p: Source = unknown / standard reference -->
      <vsat_n type="float" unit="cm/s" description="Electron saturation velocity">1.0e7</vsat_n>
      <vsat_p type="float" unit="cm/s" description="Hole saturation velocity">0.8e7</vsat_p>
    </saturation_velocity>
    
    <effective_mass>
      <!-- mc, mh: Source = unknown / standard reference -->
      <mc type="float" unit="m0" description="Electron effective mass">0.26</mc>
      <mh type="float" unit="m0" description="Hole effective mass">0.49</mh>
    </effective_mass>
    
    <ionization carrier="electron">
      <!-- Okuto-Crowell coefficients: Source = unknown / standard reference -->
      <lambda0 type="float" unit="cm" description="Optical phonon mean free path">5.4e-7</lambda0>
      <ER0 type="float" unit="eV" description="Optical phonon energy parameter">3.6e-2</ER0>
      <hw_meV type="float" unit="meV" description="Phonon energy">63.0</hw_meV>
      <Eth type="float" unit="eV" description="Threshold energy">1.8</Eth>
    </ionization>
    
    <ionization carrier="hole">
      <!-- Okuto-Crowell coefficients: Source = unknown / standard reference -->
      <lambda0 type="float" unit="cm">5.0e-7</lambda0>
      <ER0 type="float" unit="eV">3.8e-2</ER0>
      <hw_meV type="float" unit="meV">65.0</hw_meV>
      <Eth type="float" unit="eV">1.8</Eth>
    </ionization>
    
    <lifetime>
      <!-- tau_n, tau_p: Source = unknown / standard reference -->
      <tau_n type="float" unit="s" description="Electron trap lifetime">1e-6</tau_n>
      <tau_p type="float" unit="s" description="Hole trap lifetime">1e-6</tau_p>
    </lifetime>
  </material>

