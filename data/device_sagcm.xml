<?xml version="1.0" encoding="UTF-8"?>
<!--
  SAGCM (Separate Absorption, Grading, Charge, Multiplication) SPAD.

  Layer stack (top to bottom, x=0 at top surface):

    idx  material    thickness  doping      role
      0  InP          0.12 um   p+ 2e18    shallow p+ diffusion contact
      1  InP          1.50 um   i           intrinsic cap / multiplication
      2  InP          0.20 um   n+ 1e17    charge layer (field control)
      3  InGaAsP      0.12 um   i           grading layer
      4  InGaAs       1.50 um   i           absorber
      5  InP          0.50 um   n+ 5e16    buffer
      6  InP          2.00 um   n+ 1e18    substrate / n-contact

  Total thickness = 5.94 um, 500 grid nodes.
  A deep semicircular Zn diffusion defines the active-area perimeter
  through the intrinsic cap down to the charge layer.
-->
<device version="1.0" date="2026-07-08">
  <meta>
    <author>SPAD Simulator</author>
    <description>InGaAs/InP SAGCM SPAD - center-axis with deep p+ diffusion burrow.
All thicknesses in cm, doping in cm^-3.</description>
  </meta>

  <name>InGaAs/InP SAGCM SPAD</name>
  <nx type="int" unit="1" description="Number of grid nodes">500</nx>
  <temperature type="float" unit="K">300.0</temperature>

  <layers>
    <!-- p+ shallow Zn diffusion — thin contact, defines active-area perimeter -->
    <layer index="0">
      <thickness unit="cm">2.77e-4</thickness>
      <doping_type>acceptor</doping_type>
      <doping_A type="float" unit="cm^-3">4e17</doping_A>
      <material>InP</material>
    </layer>

    <!-- i-InP intrinsic cap / multiplication region — high field, impact ionisation -->
    <layer index="1">
      <thickness unit="cm">0.59e-4</thickness>
      <doping_type>donor</doping_type>
      <doping_A type="float" unit="cm^-3">1e15</doping_A>
      <material>InP</material>
    </layer>

    <!-- n+ charge sheet — sets the field ratio between multi and absorber -->
    <layer index="2">
      <thickness unit="cm">0.25e-4</thickness>
      <doping_type>donor</doping_type>
      <doping_A type="float" unit="cm^-3">1e17</doping_A>
      <material>InP</material>
    </layer>

    <!-- InGaAsP grading — smooths the valence-band step between InP and InGaAs -->
    <layer index="3">
      <thickness unit="cm">0.06e-4</thickness>
      <doping_type>donor</doping_type>
      <doping_A type="float" unit="cm^-3">1e16</doping_A>
      <material>InGaAsP</material>
    </layer>

    <!-- i-InGaAs absorber — photo-generated carriers drift into multiplication region -->
    <layer index="4">
      <thickness unit="cm">2.83e-4</thickness>
      <doping_type>donor</doping_type>
      <doping_A type="float" unit="cm^-3">1e15</doping_A>
      <material>InGaAs</material>
    </layer>

    <!-- n+ InP buffer — separates absorber from substrate -->
    <layer index="5">
      <thickness unit="cm">0.5e-4</thickness>
      <doping_type>donor</doping_type>
      <doping_A type="float" unit="cm^-3">6.6e16</doping_A>
      <material>InP</material>
    </layer>

    <!-- n+ InP substrate — ohmic contact, handled by PoissonSolver boundary conditions -->
    <layer index="6">
      <thickness unit="cm">2.0e-4</thickness>
      <doping_type>donor</doping_type>
      <doping_A type="float" unit="cm^-3">3e18</doping_A>
      <material>InP</material>
    </layer>
  </layers>
</device>
